{
  "name": "e2e_file_cascade",
  "root": true,
  "plugins": [
    {
      "id": "capture",
      "kind": "capture_file",
      "cfg": {
        "path": "/tmp/zm_e2e.mp4",
        "stream_id": 0,
        "loop": false,
        "realtime": true
      },
      "children": [
        {
          "id": "decode",
          "kind": "decode_ffmpeg",
          "cfg": { "output_format": "rgb24" },
          "queue_depth": 8,
          "children": [
            {
              "id": "motion",
              "kind": "motion_gate",
              "cfg": {
                "frame_width": 1280,
                "frame_height": 720,
                "gate": false
              },
              "queue_depth": 4,
              "children": [
                {
                  "id": "detect",
                  "kind": "detect_onnx",
                  "cfg": { "frame_width": 1280, "frame_height": 720 },
                  "queue_depth": 2
                }
              ]
            }
          ]
        },
        {
          "id": "store",
          "kind": "store",
          "cfg": { "mode": "continuous", "root": "/tmp/zm_e2e_rec", "monitor_id": 1 },
          "queue_depth": 120
        }
      ]
    }
  ]
}
